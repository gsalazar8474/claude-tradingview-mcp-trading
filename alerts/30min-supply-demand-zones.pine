//@version=5
// Elder Santis - Supply & Demand Zones
//
// Follows the exact Elder Santis zone-drawing method:
//
// SUPPLY ZONE (red):
//   Step 1 — Find a big aggressive bearish move (single massive candle OR 3 consecutive
//             bearish candles). Move must be obvious — if unsure, skip it (minMult filter).
//   Step 2 — Base = the neutral candle(s) IMMEDIATELY before that move.
//             Scan stops the moment a non-neutral candle is hit (body > neutralMax x ATR).
//   Step 3 — Top    = highest wick across all base candles
//             Bottom = lowest body-bottom across all base candles
//
// DEMAND ZONE (green):
//   Step 1 — Find a big aggressive bullish move (single massive candle OR 3 consecutive
//             bullish candles).
//   Step 2 — Base = the neutral candle(s) IMMEDIATELY before that move.
//   Step 3 — Top    = highest body-top across all base candles
//             Bottom = lowest wick across all base candles
//
// Zones extend right until price closes inside them (mitigation).
// Works on any chart timeframe — add to 4H for 4H zones, 30min for 30min zones, etc.
// Note: combining two nearby consolidation areas into one box is a manual step.

indicator("Elder Santis - Supply & Demand Zones", overlay=true, max_bars_back=500, max_boxes_count=50, max_labels_count=50)

atrLen     = input.int(14, "ATR Length", minval=1, maxval=50)
minMult    = input.float(2.0, "Min Move Size (x ATR) — raise to draw fewer, more obvious zones", minval=0.5, maxval=10.0, step=0.25)
neutralMax = input.float(0.8, "Neutral candle threshold (x ATR) — base scan stops above this", minval=0.1, maxval=3.0, step=0.1)
baseLook   = input.int(6, "Max base candle lookback", minval=1, maxval=15)
maxZones   = input.int(5, "Max active zones per side", minval=1, maxval=20)
showMit    = input.bool(false, "Show mitigated zones (greyed out)")
showEntry  = input.bool(true, "Show entry guide markers (2nd HL / 2nd LH)")
entryPLen  = input.int(3, "Entry pivot lookback (bars)", minval=2, maxval=8)
supplyCol  = input.color(color.new(color.red, 80), "Supply zone fill")
demandCol  = input.color(color.new(color.green, 80), "Demand zone fill")
mitCol     = input.color(color.new(color.gray, 90), "Mitigated zone fill")

atr = ta.atr(atrLen)

// ── BIG MOVE DETECTION ────────────────────────────────────────────────────────
// A move qualifies when its body is large AND the candle is mostly body (not wicks).
// Detects both single-candle moves and 3-consecutive-candle runs.

curBody  = math.abs(open - close)
curRange = high - low

// Single massive candle — one bar does the whole move
singleBear = open > close and curRange > 0.0 and curBody >= minMult * atr and curBody / curRange >= 0.5
singleBull = close > open and curRange > 0.0 and curBody >= minMult * atr and curBody / curRange >= 0.5

// 3-candle consecutive run — all three bars in the same direction, combined body >= threshold
threeBear = open > close and open[1] > close[1] and open[2] > close[2] and (open - close) + (open[1] - close[1]) + (open[2] - close[2]) >= minMult * atr
threeBull = close > open and close[1] > open[1] and close[2] > open[2] and (close - open) + (close[1] - open[1]) + (close[2] - open[2]) >= minMult * atr

isBigBear = barstate.isconfirmed and not na(atr) and (singleBear or threeBear)
isBigBull = barstate.isconfirmed and not na(atr) and (singleBull or threeBull)

// Base candles start immediately after the move sequence ends:
// 3-bar move → base starts at bar[3]; single-bar move → base starts at bar[1]
bearBaseStart = threeBear ? 3 : 1
bullBaseStart = threeBull ? 3 : 1

// ── ZONE STATE ARRAYS ─────────────────────────────────────────────────────────
var box[]   supplyBoxes     = array.new_box()
var bool[]  supplyHit       = array.new_bool()
var float[] supplyFirstHi   = array.new_float()
var bool[]  supplyEntryDone = array.new_bool()
var box[]   demandBoxes     = array.new_box()
var bool[]  demandHit       = array.new_bool()
var float[] demandFirstLo   = array.new_float()
var bool[]  demandEntryDone = array.new_bool()

// ── DRAW SUPPLY ZONE ──────────────────────────────────────────────────────────
if isBigBear
    // Initialise zone boundaries from the first base candle
    bs   = bearBaseStart
    zTop = na(high[bs]) ? float(na) : high[bs]
    zBot = na(open[bs]) or na(close[bs]) ? float(na) : math.min(open[bs], close[bs])
    leftBar = bar_index - bs
    // Extend backwards through neutral candles; stop at the first non-neutral candle
    for k = bs + 1 to bs + baseLook
        if na(open[k]) or na(close[k]) or na(high[k])
            break
        if math.abs(open[k] - close[k]) > neutralMax * nz(atr[k], atr)
            break
        zTop    := math.max(zTop, high[k])
        zBot    := math.min(zBot, math.min(open[k], close[k]))
        leftBar := bar_index - k
    // Draw only if we got a valid zone
    if not na(zTop) and not na(zBot) and zTop > zBot
        newBox = box.new(leftBar, zTop, bar_index, zBot, border_color=color.new(color.red, 20), bgcolor=supplyCol, border_width=1, extend=extend.right)
        array.push(supplyBoxes, newBox)
        array.push(supplyHit, false)
        array.push(supplyFirstHi, na)
        array.push(supplyEntryDone, false)
        if array.size(supplyBoxes) > maxZones
            if not array.get(supplyHit, 0)
                box.delete(array.get(supplyBoxes, 0))
            array.shift(supplyBoxes)
            array.shift(supplyHit)
            array.shift(supplyFirstHi)
            array.shift(supplyEntryDone)

// ── DRAW DEMAND ZONE ──────────────────────────────────────────────────────────
if isBigBull
    bs   = bullBaseStart
    zBot = na(low[bs]) ? float(na) : low[bs]
    zTop = na(open[bs]) or na(close[bs]) ? float(na) : math.max(open[bs], close[bs])
    leftBar = bar_index - bs
    for k = bs + 1 to bs + baseLook
        if na(open[k]) or na(close[k]) or na(low[k])
            break
        if math.abs(open[k] - close[k]) > neutralMax * nz(atr[k], atr)
            break
        zBot    := math.min(zBot, low[k])
        zTop    := math.max(zTop, math.max(open[k], close[k]))
        leftBar := bar_index - k
    if not na(zBot) and not na(zTop) and zTop > zBot
        newBox = box.new(leftBar, zTop, bar_index, zBot, border_color=color.new(color.green, 20), bgcolor=demandCol, border_width=1, extend=extend.right)
        array.push(demandBoxes, newBox)
        array.push(demandHit, false)
        array.push(demandFirstLo, na)
        array.push(demandEntryDone, false)
        if array.size(demandBoxes) > maxZones
            if not array.get(demandHit, 0)
                box.delete(array.get(demandBoxes, 0))
            array.shift(demandBoxes)
            array.shift(demandHit)
            array.shift(demandFirstLo)
            array.shift(demandEntryDone)

// ── ENTRY DETECTION ───────────────────────────────────────────────────────────
currPH  = ta.pivothigh(high, entryPLen, entryPLen)
currPL  = ta.pivotlow(low, entryPLen, entryPLen)
currAtr = ta.atr(atrLen)

// ── SUPPLY ZONES: mitigation + 2nd lower-high entry guide ─────────────────────
if array.size(supplyBoxes) > 0
    for i = 0 to array.size(supplyBoxes) - 1
        if not array.get(supplyHit, i)
            b    = array.get(supplyBoxes, i)
            zTop = box.get_top(b)
            zBot = box.get_bottom(b)
            if close <= zTop and close >= zBot
                array.set(supplyHit, i, true)
                box.set_extend(b, extend.none)
                box.set_right(b, bar_index)
                if showMit
                    box.set_bgcolor(b, mitCol)
                    box.set_border_color(b, color.new(color.gray, 60))
                else
                    box.delete(b)
            else if showEntry and not array.get(supplyEntryDone, i) and not na(currPH)
                pivH = currPH
                if pivH <= zTop + 0.5 * currAtr and pivH >= zBot - 0.5 * currAtr
                    if na(array.get(supplyFirstHi, i))
                        array.set(supplyFirstHi, i, pivH)
                    else if pivH < array.get(supplyFirstHi, i)
                        array.set(supplyEntryDone, i, true)
                        label.new(bar_index - entryPLen, pivH, "ENTRY\nSELL", color=color.new(color.orange, 10), textcolor=color.white, style=label.style_label_down, size=size.small)

// ── DEMAND ZONES: mitigation + 2nd higher-low entry guide ────────────────────
if array.size(demandBoxes) > 0
    for i = 0 to array.size(demandBoxes) - 1
        if not array.get(demandHit, i)
            b    = array.get(demandBoxes, i)
            zTop = box.get_top(b)
            zBot = box.get_bottom(b)
            if close >= zBot and close <= zTop
                array.set(demandHit, i, true)
                box.set_extend(b, extend.none)
                box.set_right(b, bar_index)
                if showMit
                    box.set_bgcolor(b, mitCol)
                    box.set_border_color(b, color.new(color.gray, 60))
                else
                    box.delete(b)
            else if showEntry and not array.get(demandEntryDone, i) and not na(currPL)
                pivL = currPL
                if pivL >= zBot - 0.5 * currAtr and pivL <= zTop + 0.5 * currAtr
                    if na(array.get(demandFirstLo, i))
                        array.set(demandFirstLo, i, pivL)
                    else if pivL > array.get(demandFirstLo, i)
                        array.set(demandEntryDone, i, true)
                        label.new(bar_index - entryPLen, pivL, "ENTRY\nBUY", color=color.new(color.blue, 10), textcolor=color.white, style=label.style_label_up, size=size.small)
