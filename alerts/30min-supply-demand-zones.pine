//@version=5
indicator("Elder Santis - Supply & Demand Zones 7", overlay=true, max_bars_back=500, max_boxes_count=500)

// ── INPUTS ────────────────────────────────────────────────────────────────────
string zoneTF     = input.timeframe("240",  "Zone Source Timeframe (240=4H, 60=1H, 30=30min)")
string refineTF   = input.timeframe("60",   "Refinement Timeframe")
bool   useRefine  = input.bool(true,        "Enable Refinement Timeframe")

int    atrLen     = input.int(14,    "ATR Length",                      minval=1,  maxval=50)
float  minMult    = input.float(1.5, "Min Impulse Body (x ATR)",        minval=0.5,maxval=10.0,step=0.25)
float  bodyRatio  = input.float(0.4, "Min body / range ratio",          minval=0.2,maxval=1.0, step=0.05)
float  neutralMax = input.float(0.5, "Base candle body max (x ATR)",    minval=0.1,maxval=2.0, step=0.1)
int    baseLook   = input.int(5,     "Max base candles to scan",        minval=1,  maxval=10)
float  baseRange  = input.float(4.0, "Max consolidation range (x ATR)", minval=0.5,maxval=8.0, step=0.25)
int    maxZones   = input.int(15,    "Max zones per side",              minval=1,  maxval=50)
bool   showMit    = input.bool(false, "Show mitigated zones")
bool   showLabel  = input.bool(true,  "Show zone label (S / D)")

color supplyFill   = input.color(color.new(#5C0000, 60), "Supply fill")
color demandFill   = input.color(color.new(#003300, 60), "Demand fill")
color mitFill      = input.color(color.new(color.gray, 88), "Mitigated fill")
color supplyBorder = input.color(color.new(#8B0000, 20), "Supply border")
color demandBorder = input.color(color.new(#004400, 20), "Demand border")

// ── ZONE DETECTION FUNCTIONS ──────────────────────────────────────────────────
// Improvement 1: Stricter 3-candle sequence — each candle must individually meet
//   body/range >= 0.5 AND body >= 0.3 x ATR, plus combined body >= minMult x ATR.
// Improvement 2: Box edges correctly use wicks for outer bounds and bodies for inner.
//   Supply  → top = max wick,     bottom = min body-bottom
//   Demand  → top = max body-top, bottom = min wick

f_supplyZone(float mult, float bRatio, float nMax, int bLook, float bRange, int al) =>
    float a      = ta.atr(al)[1]
    float zTop   = float(na)
    float zBot   = float(na)
    int   leftOff = 0
    bool  valid   = false

    if not na(a)
        // Single explosive bearish candle
        float b1 = open[1] - close[1]
        float r1 = high[1] - low[1]
        bool  s1 = open[1] > close[1] and r1 > 0.0 and b1 >= mult * a and b1 / r1 >= bRatio

        // 3-candle bearish sequence — each candle individually quality-filtered
        float r2 = high[2] - low[2]
        float r3 = high[3] - low[3]
        bool c1ok = open[1] > close[1] and r1 > 0.0 and (open[1]-close[1]) >= 0.3*a and (open[1]-close[1])/r1 >= 0.5
        bool c2ok = open[2] > close[2] and r2 > 0.0 and (open[2]-close[2]) >= 0.3*a and (open[2]-close[2])/r2 >= 0.5
        bool c3ok = open[3] > close[3] and r3 > 0.0 and (open[3]-close[3]) >= 0.3*a and (open[3]-close[3])/r3 >= 0.5
        float b3  = (open[1]-close[1]) + (open[2]-close[2]) + (open[3]-close[3])
        bool  s3  = c1ok and c2ok and c3ok and b3 >= mult * a

        int bs = s3 ? 4 : 2

        if (s1 or s3) and not na(open[bs]) and not na(close[bs])
            if math.abs(open[bs] - close[bs]) <= nMax * a
                // Supply: top = highest WICK, bottom = lowest BODY-BOTTOM
                zTop    := high[bs]
                zBot    := math.min(open[bs], close[bs])
                leftOff := bs

                for k = bs + 1 to bs + bLook
                    if na(open[k]) or na(close[k]) or na(high[k])
                        break
                    if math.abs(open[k] - close[k]) > nMax * a
                        break
                    if (math.max(zTop, high[k]) - math.min(zBot, math.min(open[k], close[k]))) > bRange * a
                        break
                    zTop    := math.max(zTop, high[k])
                    zBot    := math.min(zBot, math.min(open[k], close[k]))
                    leftOff := k

                valid := not na(zTop) and not na(zBot) and zTop > zBot
    [valid, zTop, zBot, valid ? leftOff : 0]

f_demandZone(float mult, float bRatio, float nMax, int bLook, float bRange, int al) =>
    float a      = ta.atr(al)[1]
    float zTop   = float(na)
    float zBot   = float(na)
    int   leftOff = 0
    bool  valid   = false

    if not na(a)
        // Single explosive bullish candle
        float b1 = close[1] - open[1]
        float r1 = high[1] - low[1]
        bool  s1 = close[1] > open[1] and r1 > 0.0 and b1 >= mult * a and b1 / r1 >= bRatio

        // 3-candle bullish sequence — each candle individually quality-filtered
        float r2 = high[2] - low[2]
        float r3 = high[3] - low[3]
        bool c1ok = close[1] > open[1] and r1 > 0.0 and (close[1]-open[1]) >= 0.3*a and (close[1]-open[1])/r1 >= 0.5
        bool c2ok = close[2] > open[2] and r2 > 0.0 and (close[2]-open[2]) >= 0.3*a and (close[2]-open[2])/r2 >= 0.5
        bool c3ok = close[3] > open[3] and r3 > 0.0 and (close[3]-open[3]) >= 0.3*a and (close[3]-open[3])/r3 >= 0.5
        float b3  = (close[1]-open[1]) + (close[2]-open[2]) + (close[3]-open[3])
        bool  s3  = c1ok and c2ok and c3ok and b3 >= mult * a

        int bs = s3 ? 4 : 2

        if (s1 or s3) and not na(open[bs]) and not na(close[bs])
            if math.abs(open[bs] - close[bs]) <= nMax * a
                // Demand: top = highest BODY-TOP, bottom = lowest WICK
                zTop    := math.max(open[bs], close[bs])
                zBot    := low[bs]
                leftOff := bs

                for k = bs + 1 to bs + bLook
                    if na(open[k]) or na(close[k]) or na(low[k])
                        break
                    if math.abs(open[k] - close[k]) > nMax * a
                        break
                    if (math.max(zTop, math.max(open[k], close[k])) - math.min(zBot, low[k])) > bRange * a
                        break
                    zTop    := math.max(zTop, math.max(open[k], close[k]))
                    zBot    := math.min(zBot, low[k])
                    leftOff := k

                valid := not na(zTop) and not na(zBot) and zTop > zBot
    [valid, zTop, zBot, valid ? leftOff : 0]

// ── CONTINUATION ZONE FUNCTIONS ───────────────────────────────────────────────
// Continuation Supply: 2+ strong bearish candles → 1-4 pullback candles up → 1+ bearish resumption
//   Zone drawn from the PULLBACK candles: top=max wick, bottom=min body-bottom
// Continuation Demand: 2+ strong bullish candles → 1-4 pullback candles down → 1+ bullish resumption
//   Zone drawn from the PULLBACK candles: top=max body-top, bottom=min wick

f_supplyContZone(float mult, int al) =>
    float a      = ta.atr(al)[1]
    float zTop   = float(na)
    float zBot   = float(na)
    int   leftOff = 0
    bool  valid   = false
    if not na(a)
        // bar[0] = strong bearish resumption (body >= 0.8 x ATR)
        bool resumeOk = open > close and (open - close) >= 0.8 * a
        if resumeOk
            // Count consecutive bullish pullback candles in bar[1..4] (body <= 1.5 x ATR)
            int pullLen = 0
            for k = 1 to 4
                if close[k] >= open[k] and (close[k] - open[k]) <= 1.5 * a
                    pullLen := k
                else
                    break
            if pullLen >= 1
                // Initial bearish move: bar[pullLen+1] and bar[pullLen+2] combined body >= minMult x ATR
                int   p1      = pullLen + 1
                int   p2      = pullLen + 2
                float preBody = (open[p1] > close[p1] ? open[p1] - close[p1] : 0.0) + (open[p2] > close[p2] ? open[p2] - close[p2] : 0.0)
                if preBody >= mult * a
                    // Zone = pullback candles bar[1..pullLen]
                    zTop    := high[1]
                    zBot    := math.min(open[1], close[1])
                    leftOff := pullLen
                    for k = 2 to pullLen
                        zTop := math.max(zTop, high[k])
                        zBot := math.min(zBot, math.min(open[k], close[k]))
                    valid := zTop > zBot
    [valid, zTop, zBot, valid ? leftOff : 0]

f_demandContZone(float mult, int al) =>
    float a      = ta.atr(al)[1]
    float zTop   = float(na)
    float zBot   = float(na)
    int   leftOff = 0
    bool  valid   = false
    if not na(a)
        // bar[0] = strong bullish resumption (body >= 0.8 x ATR)
        bool resumeOk = close > open and (close - open) >= 0.8 * a
        if resumeOk
            // Count consecutive bearish pullback candles in bar[1..4] (body <= 1.5 x ATR)
            int pullLen = 0
            for k = 1 to 4
                if open[k] >= close[k] and (open[k] - close[k]) <= 1.5 * a
                    pullLen := k
                else
                    break
            if pullLen >= 1
                // Initial bullish move: bar[pullLen+1] and bar[pullLen+2] combined body >= minMult x ATR
                int   p1      = pullLen + 1
                int   p2      = pullLen + 2
                float preBody = (close[p1] > open[p1] ? close[p1] - open[p1] : 0.0) + (close[p2] > open[p2] ? close[p2] - open[p2] : 0.0)
                if preBody >= mult * a
                    // Zone = pullback candles bar[1..pullLen]
                    zTop    := math.max(open[1], close[1])
                    zBot    := low[1]
                    leftOff := pullLen
                    for k = 2 to pullLen
                        zTop := math.max(zTop, math.max(open[k], close[k]))
                        zBot := math.min(zBot, low[k])
                    valid := zTop > zBot
    [valid, zTop, zBot, valid ? leftOff : 0]

// ── FETCH FROM ZONE TF AND REFINEMENT TF ─────────────────────────────────────
[htf_sValid, htf_sTop, htf_sBot, htf_sOff] = request.security(syminfo.tickerid, zoneTF, f_supplyZone(minMult, bodyRatio, neutralMax, baseLook, baseRange, atrLen), barmerge.gaps_off, barmerge.lookahead_off)
[htf_dValid, htf_dTop, htf_dBot, htf_dOff] = request.security(syminfo.tickerid, zoneTF, f_demandZone(minMult, bodyRatio, neutralMax, baseLook, baseRange, atrLen), barmerge.gaps_off, barmerge.lookahead_off)
[ref_sValid, ref_sTop, ref_sBot, ref_sOff] = request.security(syminfo.tickerid, refineTF, f_supplyZone(minMult, bodyRatio, neutralMax, baseLook, baseRange, atrLen), barmerge.gaps_off, barmerge.lookahead_off)
[ref_dValid, ref_dTop, ref_dBot, ref_dOff] = request.security(syminfo.tickerid, refineTF, f_demandZone(minMult, bodyRatio, neutralMax, baseLook, baseRange, atrLen), barmerge.gaps_off, barmerge.lookahead_off)

// Departure extremes — used for zone strength tier calculation
// Supply departure = lowest low reached by the impulse candle(s) in the HTF context
// Demand departure = highest high reached by the impulse candle(s)
htf_sDepLow  = request.security(syminfo.tickerid, zoneTF, math.min(low[1], math.min(low[2], low[3])), barmerge.gaps_off, barmerge.lookahead_off)
htf_dDepHigh = request.security(syminfo.tickerid, zoneTF, math.max(high[1], math.max(high[2], high[3])), barmerge.gaps_off, barmerge.lookahead_off)

// ── REFINEMENT (Improvement 3) ────────────────────────────────────────────────
// When the lower-TF zone overlaps the HTF zone by >= 50% of the HTF zone height,
// tighten the box to the lower-TF edges (clamped to stay inside the HTF zone).
// This replaces the old full-containment check.

f_refineSupply(float htfTop, float htfBot, bool rValid, float rTop, float rBot) =>
    float htfH      = htfTop - htfBot
    float overlapH  = math.max(0.0, math.min(htfTop, rTop) - math.max(htfBot, rBot))
    bool  canRefine = rValid and useRefine and htfH > 0.0 and overlapH / htfH >= 0.5
    float fTop      = canRefine ? math.min(htfTop, rTop) : htfTop
    float fBot      = canRefine ? math.max(htfBot, rBot) : htfBot
    // Guard: if refinement collapsed the zone, fall back to HTF
    [fTop > fBot ? fTop : htfTop, fTop > fBot ? fBot : htfBot]

f_refineDemand(float htfTop, float htfBot, bool rValid, float rTop, float rBot) =>
    float htfH      = htfTop - htfBot
    float overlapH  = math.max(0.0, math.min(htfTop, rTop) - math.max(htfBot, rBot))
    bool  canRefine = rValid and useRefine and htfH > 0.0 and overlapH / htfH >= 0.5
    float fTop      = canRefine ? math.min(htfTop, rTop) : htfTop
    float fBot      = canRefine ? math.max(htfBot, rBot) : htfBot
    [fTop > fBot ? fTop : htfTop, fTop > fBot ? fBot : htfBot]

// ── ZONE STORAGE ──────────────────────────────────────────────────────────────
int   htf_bidx   = request.security(syminfo.tickerid, zoneTF, bar_index, barmerge.gaps_off, barmerge.lookahead_off)
bool  is_new_htf = ta.change(htf_bidx) > 0
float htfToChart = math.max(1.0, timeframe.in_seconds(zoneTF) / timeframe.in_seconds())

var box[]  supplyBoxes = array.new_box()
var bool[] supplyHit   = array.new_bool()
var box[]  demandBoxes = array.new_box()
var bool[] demandHit   = array.new_bool()

// ── DRAW SUPPLY ZONE ──────────────────────────────────────────────────────────
if is_new_htf and htf_sValid
    [finalTop, finalBot] = f_refineSupply(htf_sTop, htf_sBot, ref_sValid, ref_sTop, ref_sBot)
    int leftBar = math.max(0, bar_index - math.round(htf_sOff * htfToChart))
    box b = box.new(leftBar, finalTop, bar_index, finalBot,
         border_color=supplyBorder, bgcolor=supplyFill, border_width=2, extend=extend.right)
    if showLabel
        box.set_text(b, "S")
        box.set_text_color(b, color.new(color.white, 0))
        box.set_text_size(b, size.small)
        box.set_text_halign(b, text.align_left)
        box.set_text_valign(b, text.align_top)
    array.push(supplyBoxes, b)
    array.push(supplyHit, false)
    if array.size(supplyBoxes) > maxZones
        box oldest = array.shift(supplyBoxes)
        if not array.shift(supplyHit)
            box.delete(oldest)

// ── SUPPLY ZONE STRENGTH TIER LABEL ──────────────────────────────────────────
// Tier 1 >= 800 pts, Tier 2 400-799 pts, Tier 3 200-399 pts
if is_new_htf and htf_sValid and showLabel and array.size(supplyBoxes) > 0
    float sMoveSize = not na(htf_sDepLow) ? htf_sTop - htf_sDepLow : 0.0
    string sTier    = sMoveSize >= 800 ? "S1" : sMoveSize >= 400 ? "S2" : sMoveSize >= 200 ? "S3" : "S"
    if not array.get(supplyHit, array.size(supplyHit) - 1)
        box.set_text(array.get(supplyBoxes, array.size(supplyBoxes) - 1), sTier)

// ── DRAW DEMAND ZONE ──────────────────────────────────────────────────────────
if is_new_htf and htf_dValid
    [finalTop, finalBot] = f_refineDemand(htf_dTop, htf_dBot, ref_dValid, ref_dTop, ref_dBot)
    int leftBar = math.max(0, bar_index - math.round(htf_dOff * htfToChart))
    box b = box.new(leftBar, finalTop, bar_index, finalBot,
         border_color=demandBorder, bgcolor=demandFill, border_width=2, extend=extend.right)
    if showLabel
        box.set_text(b, "D")
        box.set_text_color(b, color.new(color.white, 0))
        box.set_text_size(b, size.small)
        box.set_text_halign(b, text.align_left)
        box.set_text_valign(b, text.align_top)
    array.push(demandBoxes, b)
    array.push(demandHit, false)
    if array.size(demandBoxes) > maxZones
        box oldest = array.shift(demandBoxes)
        if not array.shift(demandHit)
            box.delete(oldest)

// ── DEMAND ZONE STRENGTH TIER LABEL ──────────────────────────────────────────
if is_new_htf and htf_dValid and showLabel and array.size(demandBoxes) > 0
    float dMoveSize = not na(htf_dDepHigh) ? htf_dDepHigh - htf_dBot : 0.0
    string dTier    = dMoveSize >= 800 ? "D1" : dMoveSize >= 400 ? "D2" : dMoveSize >= 200 ? "D3" : "D"
    if not array.get(demandHit, array.size(demandHit) - 1)
        box.set_text(array.get(demandBoxes, array.size(demandBoxes) - 1), dTier)

// ── ROLE REVERSAL ─────────────────────────────────────────────────────────────
// Impulsive break (body >= 1.5 x ATR AND body/range >= 0.5) flips the zone to the opposite role.
// Slow grind break (body < 1.0 x ATR) falls through to normal mitigation below.
// Run BEFORE existing mitigation so impulsive breaks are marked hit first.
var box[]  supplyFlipped    = array.new_box()
var bool[] supplyFlippedHit = array.new_bool()
var box[]  demandFlipped    = array.new_box()
var bool[] demandFlippedHit = array.new_bool()

float rvAtr   = ta.atr(atrLen)
float rvBody  = math.abs(open - close)
float rvRange = math.max(high - low, 0.0001)
bool  rvImp   = barstate.isconfirmed and not na(rvAtr) and rvBody >= 1.5 * rvAtr and rvBody / rvRange >= 0.5

if rvImp and array.size(supplyBoxes) > 0
    for i = 0 to array.size(supplyBoxes) - 1
        if not array.get(supplyHit, i)
            box b = array.get(supplyBoxes, i)
            if close > box.get_top(b)
                array.set(supplyHit, i, true)      // block existing mitigation from deleting it
                box.set_bgcolor(b, demandFill)
                box.set_border_color(b, demandBorder)
                if showLabel
                    box.set_text(b, "D (flipped)")
                array.push(supplyFlipped, b)
                array.push(supplyFlippedHit, false)

if rvImp and array.size(demandBoxes) > 0
    for i = 0 to array.size(demandBoxes) - 1
        if not array.get(demandHit, i)
            box b = array.get(demandBoxes, i)
            if close < box.get_bottom(b)
                array.set(demandHit, i, true)
                box.set_bgcolor(b, supplyFill)
                box.set_border_color(b, supplyBorder)
                if showLabel
                    box.set_text(b, "S (flipped)")
                array.push(demandFlipped, b)
                array.push(demandFlippedHit, false)

// ── MITIGATION ────────────────────────────────────────────────────────────────
// Supply removed when close > zone top (broke above). Demand removed when close < zone bottom.
if barstate.isconfirmed and array.size(supplyBoxes) > 0
    for i = 0 to array.size(supplyBoxes) - 1
        if not array.get(supplyHit, i)
            box b = array.get(supplyBoxes, i)
            if close > box.get_top(b)
                array.set(supplyHit, i, true)
                box.set_extend(b, extend.none)
                box.set_right(b, bar_index)
                if showMit
                    box.set_bgcolor(b, mitFill)
                    box.set_border_color(b, color.new(color.gray, 50))
                else
                    box.delete(b)

if barstate.isconfirmed and array.size(demandBoxes) > 0
    for i = 0 to array.size(demandBoxes) - 1
        if not array.get(demandHit, i)
            box b = array.get(demandBoxes, i)
            if close < box.get_bottom(b)
                array.set(demandHit, i, true)
                box.set_extend(b, extend.none)
                box.set_right(b, bar_index)
                if showMit
                    box.set_bgcolor(b, mitFill)
                    box.set_border_color(b, color.new(color.gray, 50))
                else
                    box.delete(b)

// ── FLIPPED ZONE MITIGATION ───────────────────────────────────────────────────
// Former supply zones (flipped to demand) → remove when close < zone bottom
// Former demand zones (flipped to supply) → remove when close > zone top
if barstate.isconfirmed and array.size(supplyFlipped) > 0
    for i = 0 to array.size(supplyFlipped) - 1
        if not array.get(supplyFlippedHit, i)
            box b = array.get(supplyFlipped, i)
            if close < box.get_bottom(b)
                array.set(supplyFlippedHit, i, true)
                box.set_extend(b, extend.none)
                box.set_right(b, bar_index)
                if showMit
                    box.set_bgcolor(b, mitFill)
                    box.set_border_color(b, color.new(color.gray, 50))
                else
                    box.delete(b)

if barstate.isconfirmed and array.size(demandFlipped) > 0
    for i = 0 to array.size(demandFlipped) - 1
        if not array.get(demandFlippedHit, i)
            box b = array.get(demandFlipped, i)
            if close > box.get_top(b)
                array.set(demandFlippedHit, i, true)
                box.set_extend(b, extend.none)
                box.set_right(b, bar_index)
                if showMit
                    box.set_bgcolor(b, mitFill)
                    box.set_border_color(b, color.new(color.gray, 50))
                else
                    box.delete(b)
