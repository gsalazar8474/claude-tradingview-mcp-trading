//@version=5
// Elder Santis - Supply & Demand Zones
//
// Works on ANY chart timeframe. Add to 4H → 4H zones. Add to 30min → 30min zones.
// Trader manually refines down through timeframes.
//
// DETECTION (on every confirmed bar):
//   Explosive move = single candle body >= minMult x ATR AND body/range >= bodyRatio
//                 OR 3 consecutive same-direction candles, combined body >= minMult x ATR
//
// BASE (candles immediately before the explosive move):
//   Neutral candle = body <= neutralMax x ATR (small body, opened/closed near same price)
//   Scan back up to baseLook candles, stop when body exceeds neutralMax x ATR
//
// ZONE BOUNDARIES:
//   Supply  → top = highest WICK of base,     bottom = lowest BODY-BOTTOM of base
//   Demand  → top = highest BODY-TOP of base, bottom = lowest WICK of base

indicator("Elder Santis - Supply & Demand Zones", overlay=true, max_bars_back=500, max_boxes_count=100)

atrLen     = input.int(14,    "ATR Length",                   minval=1,  maxval=50)
minMult    = input.float(2.0, "Impulse body min (x ATR)",    minval=0.5, maxval=10.0, step=0.25)
bodyRatio  = input.float(0.5, "Impulse body / range min",    minval=0.3, maxval=1.0,  step=0.05)
neutralMax = input.float(0.5, "Base candle body max (x ATR)",minval=0.1, maxval=2.0,  step=0.1)
baseLook   = input.int(10,    "Max base candles to scan",    minval=1,  maxval=20)
maxZones   = input.int(8,     "Max zones per side",          minval=1,  maxval=20)
showMit    = input.bool(false, "Show mitigated zones")
supplyFill   = input.color(color.new(color.red,   60), "Supply fill")
demandFill   = input.color(color.new(color.green, 60), "Demand fill")
mitFill      = input.color(color.new(color.gray,  88), "Mitigated fill")
supplyBorder = input.color(color.new(color.red,    0), "Supply border")
demandBorder = input.color(color.new(color.green,  0), "Demand border")

atr = ta.atr(atrLen)

// ── EXPLOSIVE MOVE DETECTION ──────────────────────────────────────────────────
// Detected on bar[0] (current bar, just confirmed).

curBody  = math.abs(open - close)
curRange = high - low

singleBear = open > close and curRange > 0.0 and curBody >= minMult * atr and curBody / curRange >= bodyRatio
singleBull = close > open and curRange > 0.0 and curBody >= minMult * atr and curBody / curRange >= bodyRatio

bear3body = (open   > close   ? open   - close   : 0.0) + (open[1] > close[1] ? open[1] - close[1] : 0.0) + (open[2] > close[2] ? open[2] - close[2] : 0.0)
bull3body = (close  > open    ? close  - open    : 0.0) + (close[1] > open[1] ? close[1] - open[1] : 0.0) + (close[2] > open[2] ? close[2] - open[2] : 0.0)
threeBear = open > close and open[1] > close[1] and open[2] > close[2] and bear3body >= minMult * atr
threeBull = close > open and close[1] > open[1] and close[2] > open[2] and bull3body >= minMult * atr

isBigBear = barstate.isconfirmed and not na(atr) and (singleBear or threeBear)
isBigBull = barstate.isconfirmed and not na(atr) and (singleBull or threeBull)

// Base starts at bar[1] after a single-candle move, bar[3] after a 3-candle run
bearBase = threeBear ? 3 : 1
bullBase = threeBull ? 3 : 1

// ── ZONE STORAGE ──────────────────────────────────────────────────────────────
var box[]  supplyBoxes = array.new_box()
var bool[] supplyHit   = array.new_bool()
var box[]  demandBoxes = array.new_box()
var bool[] demandHit   = array.new_bool()

// ── SUPPLY ZONE ───────────────────────────────────────────────────────────────
// The FIRST base candle (bar[bs]) must itself be neutral — if it isn't,
// the explosive move is just a continuation inside a trend, not a new move
// off a consolidation. Skip the zone entirely in that case.
if isBigBear
    bs       = bearBase
    baseAtr0 = nz(atr[bs], atr)
    firstNeutral = not na(open[bs]) and not na(close[bs]) and math.abs(open[bs] - close[bs]) <= neutralMax * baseAtr0
    if firstNeutral
        zTop    = high[bs]
        zBot    = math.min(open[bs], close[bs])
        leftBar = bar_index - bs
        for k = bs + 1 to bs + baseLook
            if na(open[k]) or na(close[k]) or na(high[k])
                break
            if math.abs(open[k] - close[k]) > neutralMax * nz(atr[k], atr)
                break
            zTop    := math.max(zTop, high[k])
            zBot    := math.min(zBot, math.min(open[k], close[k]))
            leftBar := bar_index - k
        if zTop > zBot
            b = box.new(leftBar, zTop, bar_index, zBot, border_color=supplyBorder, bgcolor=supplyFill, border_width=2, extend=extend.right)
            array.push(supplyBoxes, b)
            array.push(supplyHit, false)
            if array.size(supplyBoxes) > maxZones
                oldest = array.shift(supplyBoxes)
                if not array.shift(supplyHit)
                    box.delete(oldest)

// ── DEMAND ZONE ───────────────────────────────────────────────────────────────
if isBigBull
    bs       = bullBase
    baseAtr0 = nz(atr[bs], atr)
    firstNeutral = not na(open[bs]) and not na(close[bs]) and math.abs(open[bs] - close[bs]) <= neutralMax * baseAtr0
    if firstNeutral
        zBot    = low[bs]
        zTop    = math.max(open[bs], close[bs])
        leftBar = bar_index - bs
        for k = bs + 1 to bs + baseLook
            if na(open[k]) or na(close[k]) or na(low[k])
                break
            if math.abs(open[k] - close[k]) > neutralMax * nz(atr[k], atr)
                break
            zBot    := math.min(zBot, low[k])
            zTop    := math.max(zTop, math.max(open[k], close[k]))
            leftBar := bar_index - k
        if zTop > zBot
            b = box.new(leftBar, zTop, bar_index, zBot, border_color=demandBorder, bgcolor=demandFill, border_width=2, extend=extend.right)
            array.push(demandBoxes, b)
            array.push(demandHit, false)
            if array.size(demandBoxes) > maxZones
                oldest = array.shift(demandBoxes)
                if not array.shift(demandHit)
                    box.delete(oldest)

// ── MITIGATION ────────────────────────────────────────────────────────────────
if array.size(supplyBoxes) > 0
    for i = 0 to array.size(supplyBoxes) - 1
        if not array.get(supplyHit, i)
            b = array.get(supplyBoxes, i)
            if close <= box.get_top(b) and close >= box.get_bottom(b)
                array.set(supplyHit, i, true)
                box.set_extend(b, extend.none)
                box.set_right(b, bar_index)
                if showMit
                    box.set_bgcolor(b, mitFill)
                    box.set_border_color(b, color.new(color.gray, 50))
                else
                    box.delete(b)

if array.size(demandBoxes) > 0
    for i = 0 to array.size(demandBoxes) - 1
        if not array.get(demandHit, i)
            b = array.get(demandBoxes, i)
            if close >= box.get_bottom(b) and close <= box.get_top(b)
                array.set(demandHit, i, true)
                box.set_extend(b, extend.none)
                box.set_right(b, bar_index)
                if showMit
                    box.set_bgcolor(b, mitFill)
                    box.set_border_color(b, color.new(color.gray, 50))
                else
                    box.delete(b)
