//@version=5
// Elder Santis - Supply & Demand Zones
// Synthesised from 6 YouTube transcripts (2026-04-28) + rules.json
//
// THEORY (Elder Santis, verbatim):
//   "Big moves take hundreds of millions of dollars. Only institutions can
//    create them. That is how we know where the big money sits — when the
//    big move happens, the consolidation before it is where orders were
//    filled. When price returns, those same participants may defend it again."
//
// ─── SUPPLY ZONE (red) ───────────────────────────────────────────────────────
//   1. Find an OBVIOUS explosive move DOWN
//      → one huge red candle  OR  3 consecutive momentum red candles
//      → must be aggressive, obvious — if unsure, skip it
//   2. Find the neutral candle / consolidation IMMEDIATELY before that move
//      → neutral candle = small body (opened and closed near same price), big wicks
//      → consolidation  = 2-4 tight candles before the move
//   3. Draw the box:
//      → TOP    = highest WICK  of all base candles
//      → BOTTOM = lowest  BODY-BOTTOM of all base candles
//
// ─── DEMAND ZONE (green) ─────────────────────────────────────────────────────
//   1. Find an OBVIOUS explosive move UP
//      → one huge green candle  OR  3 consecutive momentum green candles
//   2. Find the neutral candle / consolidation IMMEDIATELY before that move
//   3. Draw the box:
//      → TOP    = highest BODY-TOP of all base candles
//      → BOTTOM = lowest  WICK  of all base candles
//
// ─── INVALIDATION ────────────────────────────────────────────────────────────
//   Zone is invalid when price CLOSES through it on the 30min chart.
//   A wick through the zone is NOT invalidation.
//
// ─── TIMEFRAME USE ───────────────────────────────────────────────────────────
//   Add this indicator at each timeframe. Start at 4H, refine to 30min.
//   If 30min shows no visible consolidation (straight spike), drop to 15min
//   to find the hidden base, then draw the zone there.

indicator("Elder Santis - Supply & Demand Zones", overlay=true, max_bars_back=500, max_boxes_count=50)

// ── INPUTS ────────────────────────────────────────────────────────────────────
atrLen     = input.int(14,    "ATR Length",                       minval=1, maxval=50)
minMult    = input.float(2.0, "Impulse body minimum (x ATR)",    minval=0.5, maxval=10.0, step=0.25,
             tooltip="How large the explosive candle body must be relative to ATR. Raise to draw only the most obvious zones.")
bodyRatio  = input.float(0.5, "Impulse body / range minimum",    minval=0.3, maxval=1.0, step=0.05,
             tooltip="Explosive candle body must be at least this fraction of its range. Filters wicky, indecisive candles.")
neutralMax = input.float(0.5, "Base candle body maximum (x ATR)",minval=0.1, maxval=2.0, step=0.1,
             tooltip="Base (neutral) candles must have small bodies. Scan stops when a candle body exceeds this.")
baseLook   = input.int(6,     "Max base candles to scan",        minval=1, maxval=15,
             tooltip="How many candles before the explosive move to include in the base zone.")
maxZones   = input.int(5,     "Max zones per side",              minval=1, maxval=20)
showMit    = input.bool(false, "Show mitigated zones (greyed out)")
supplyFill   = input.color(color.new(color.red,   60), "Supply fill")
demandFill   = input.color(color.new(color.green, 60), "Demand fill")
mitFill      = input.color(color.new(color.gray,  88), "Mitigated fill")
supplyBorder = input.color(color.new(color.red,    0), "Supply border")
demandBorder = input.color(color.new(color.green,  0), "Demand border")

atr = ta.atr(atrLen)

// ── EXPLOSIVE MOVE DETECTION ──────────────────────────────────────────────────
// Detect on bar[0] (current bar, just confirmed by barstate.isconfirmed).
// "One huge body candle OR 3 consecutive same-direction candles" — Elder Santis

curBody  = math.abs(open - close)
curRange = high - low

// Single explosive candle: large body, body dominates the range
singleBear = open > close and curRange > 0.0 and curBody >= minMult * atr and curBody / curRange >= bodyRatio
singleBull = close > open and curRange > 0.0 and curBody >= minMult * atr and curBody / curRange >= bodyRatio

// 3 consecutive candles all in the same direction, combined body >= threshold
bear3body = (open > close ? open - close : 0.0) + (open[1] > close[1] ? open[1] - close[1] : 0.0) + (open[2] > close[2] ? open[2] - close[2] : 0.0)
bull3body = (close > open ? close - open : 0.0) + (close[1] > open[1] ? close[1] - open[1] : 0.0) + (close[2] > open[2] ? close[2] - open[2] : 0.0)
threeBear = open > close and open[1] > close[1] and open[2] > close[2] and bear3body >= minMult * atr
threeBull = close > open and close[1] > open[1] and close[2] > open[2] and bull3body >= minMult * atr

isBigBear = barstate.isconfirmed and not na(atr) and (singleBear or threeBear)
isBigBull = barstate.isconfirmed and not na(atr) and (singleBull or threeBull)

// Base starts immediately after the explosive sequence ends
// 3-bar move → base at bar[3]; single bar → base at bar[1]
bearBase = threeBear ? 3 : 1
bullBase = threeBull ? 3 : 1

// ── ZONE STORAGE ──────────────────────────────────────────────────────────────
var box[]  supplyBoxes = array.new_box()
var bool[] supplyHit   = array.new_bool()
var box[]  demandBoxes = array.new_box()
var bool[] demandHit   = array.new_bool()

// ── SUPPLY ZONE ───────────────────────────────────────────────────────────────
// Base scan: include neutral candles (small body) BEFORE the explosive move.
// Stop the moment any candle body exceeds neutralMax x ATR — that candle is not neutral.
// Zone: TOP = highest wick of base, BOTTOM = lowest body-bottom of base
if isBigBear
    bs      = bearBase
    zTop    = na(high[bs]) ? float(na) : high[bs]
    zBot    = na(open[bs]) or na(close[bs]) ? float(na) : math.min(open[bs], close[bs])
    leftBar = bar_index - bs
    for k = bs + 1 to bs + baseLook
        if na(open[k]) or na(close[k]) or na(high[k])
            break
        if math.abs(open[k] - close[k]) > neutralMax * nz(atr[k], atr)
            break
        zTop    := math.max(zTop, high[k])
        zBot    := math.min(zBot, math.min(open[k], close[k]))
        leftBar := bar_index - k
    if not na(zTop) and not na(zBot) and zTop > zBot
        b = box.new(leftBar, zTop, bar_index, zBot, border_color=supplyBorder, bgcolor=supplyFill, border_width=2, extend=extend.right)
        array.push(supplyBoxes, b)
        array.push(supplyHit, false)
        if array.size(supplyBoxes) > maxZones
            oldest = array.shift(supplyBoxes)
            if not array.shift(supplyHit)
                box.delete(oldest)

// ── DEMAND ZONE ───────────────────────────────────────────────────────────────
// Zone: TOP = highest body-top of base, BOTTOM = lowest wick of base
if isBigBull
    bs      = bullBase
    zBot    = na(low[bs]) ? float(na) : low[bs]
    zTop    = na(open[bs]) or na(close[bs]) ? float(na) : math.max(open[bs], close[bs])
    leftBar = bar_index - bs
    for k = bs + 1 to bs + baseLook
        if na(open[k]) or na(close[k]) or na(low[k])
            break
        if math.abs(open[k] - close[k]) > neutralMax * nz(atr[k], atr)
            break
        zBot    := math.min(zBot, low[k])
        zTop    := math.max(zTop, math.max(open[k], close[k]))
        leftBar := bar_index - k
    if not na(zBot) and not na(zTop) and zTop > zBot
        b = box.new(leftBar, zTop, bar_index, zBot, border_color=demandBorder, bgcolor=demandFill, border_width=2, extend=extend.right)
        array.push(demandBoxes, b)
        array.push(demandHit, false)
        if array.size(demandBoxes) > maxZones
            oldest = array.shift(demandBoxes)
            if not array.shift(demandHit)
                box.delete(oldest)

// ── MITIGATION ────────────────────────────────────────────────────────────────
// Zone is mitigated when price CLOSES inside it — NOT just a wick or touch.
// (Elder Santis: "it has to be a CLOSE through on the 30min — wick is not invalidation")
if array.size(supplyBoxes) > 0
    for i = 0 to array.size(supplyBoxes) - 1
        if not array.get(supplyHit, i)
            b = array.get(supplyBoxes, i)
            if close <= box.get_top(b) and close >= box.get_bottom(b)
                array.set(supplyHit, i, true)
                box.set_extend(b, extend.none)
                box.set_right(b, bar_index)
                if showMit
                    box.set_bgcolor(b, mitFill)
                    box.set_border_color(b, color.new(color.gray, 50))
                else
                    box.delete(b)

if array.size(demandBoxes) > 0
    for i = 0 to array.size(demandBoxes) - 1
        if not array.get(demandHit, i)
            b = array.get(demandBoxes, i)
            if close >= box.get_bottom(b) and close <= box.get_top(b)
                array.set(demandHit, i, true)
                box.set_extend(b, extend.none)
                box.set_right(b, bar_index)
                if showMit
                    box.set_bgcolor(b, mitFill)
                    box.set_border_color(b, color.new(color.gray, 50))
                else
                    box.delete(b)
