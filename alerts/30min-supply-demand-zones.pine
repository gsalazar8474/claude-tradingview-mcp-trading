//@version=5
// Elder Santis - Supply & Demand Zones
//
// Zones always come from the "Zone Source Timeframe" (default 4H).
// The same zones appear on every chart — 4H, 1H, 30min, 5min.
//
// SUPPLY: explosive bearish move off a neutral base
//   Top = highest wick of base candles
//   Bottom = lowest body-bottom of base candles
//
// DEMAND: explosive bullish move off a neutral base
//   Top = highest body-top of base candles
//   Bottom = lowest wick of base candles
//
// Base candle must itself be neutral (body <= neutralMax x ATR).
// Zones extend right until price closes inside them.

indicator("Elder Santis - Supply & Demand Zones", overlay=true, max_bars_back=500, max_boxes_count=200)

// ── INPUTS ────────────────────────────────────────────────────────────────────
zoneTF     = input.timeframe("240",  "Zone Source Timeframe (240=4H, 60=1H, 30=30min)")
atrLen     = input.int(14,    "ATR Length",                    minval=1, maxval=50)
minMult    = input.float(1.5, "Min Impulse Body (x ATR)",     minval=0.5, maxval=10.0, step=0.25)
bodyRatio  = input.float(0.5, "Min body / range ratio",        minval=0.3, maxval=1.0,  step=0.05)
neutralMax = input.float(0.5, "Base candle body max (x ATR)", minval=0.1, maxval=2.0,  step=0.1)
baseLook   = input.int(5,     "Max base candles to scan",     minval=1,  maxval=10)
maxZones   = input.int(20,    "Max zones per side",           minval=1,  maxval=50)
showMit    = input.bool(false, "Show mitigated zones (greyed out)")
supplyFill   = input.color(color.new(color.red,   60), "Supply fill")
demandFill   = input.color(color.new(color.green, 60), "Demand fill")
mitFill      = input.color(color.new(color.gray,  88), "Mitigated fill")
supplyBorder = input.color(color.new(color.red,    0), "Supply border")
demandBorder = input.color(color.new(color.green,  0), "Demand border")

// ── ZONE DETECTION (runs inside request.security in the source TF) ────────────
// bar[1] = last confirmed source-TF bar → checked for the explosive move
// bar[bs]+ = base candles before that move

f_supplyZone(mult, bRatio, nMax, bLook, al) =>
    a   = ta.atr(al)[1]
    b1  = open[1] - close[1]
    r1  = high[1] - low[1]
    s1  = not na(a) and open[1] > close[1] and r1 > 0.0 and b1 >= mult * a and b1 / r1 >= bRatio
    b3  = (open[1] > close[1] ? open[1] - close[1] : 0.0) + (open[2] > close[2] ? open[2] - close[2] : 0.0) + (open[3] > close[3] ? open[3] - close[3] : 0.0)
    s3  = open[1] > close[1] and open[2] > close[2] and open[3] > close[3] and b3 >= mult * nz(a, 1.0)
    bs  = s3 ? 4 : 2
    zTop     = float(na)
    zBot     = float(na)
    leftOff  = bs
    if (s1 or s3) and not na(open[bs]) and not na(close[bs])
        baseBody = math.abs(open[bs] - close[bs])
        if baseBody <= nMax * a
            zTop   := high[bs]
            zBot   := math.min(open[bs], close[bs])
            for k = bs + 1 to bs + bLook
                if na(open[k]) or na(close[k]) or na(high[k])
                    break
                if math.abs(open[k] - close[k]) > nMax * a
                    break
                zTop    := math.max(zTop, high[k])
                zBot    := math.min(zBot, math.min(open[k], close[k]))
                leftOff := k
    leftTime = not na(zTop) and zTop > zBot ? time[leftOff] : int(na)
    [not na(zTop) and zTop > zBot, zTop, zBot, leftTime]

f_demandZone(mult, bRatio, nMax, bLook, al) =>
    a   = ta.atr(al)[1]
    b1  = close[1] - open[1]
    r1  = high[1] - low[1]
    s1  = not na(a) and close[1] > open[1] and r1 > 0.0 and b1 >= mult * a and b1 / r1 >= bRatio
    b3  = (close[1] > open[1] ? close[1] - open[1] : 0.0) + (close[2] > open[2] ? close[2] - open[2] : 0.0) + (close[3] > open[3] ? close[3] - open[3] : 0.0)
    s3  = close[1] > open[1] and close[2] > open[2] and close[3] > open[3] and b3 >= mult * nz(a, 1.0)
    bs  = s3 ? 4 : 2
    zBot     = float(na)
    zTop     = float(na)
    leftOff  = bs
    if (s1 or s3) and not na(open[bs]) and not na(close[bs])
        baseBody = math.abs(open[bs] - close[bs])
        if baseBody <= nMax * a
            zBot   := low[bs]
            zTop   := math.max(open[bs], close[bs])
            for k = bs + 1 to bs + bLook
                if na(open[k]) or na(close[k]) or na(low[k])
                    break
                if math.abs(open[k] - close[k]) > nMax * a
                    break
                zBot    := math.min(zBot, low[k])
                zTop    := math.max(zTop, math.max(open[k], close[k]))
                leftOff := k
    leftTime = not na(zBot) and zTop > zBot ? time[leftOff] : int(na)
    [not na(zBot) and zTop > zBot, zBot, zTop, leftTime]

// ── FETCH ZONE DATA FROM SOURCE TF ───────────────────────────────────────────
[htf_sBear, htf_sTop, htf_sBot, htf_sTime] = request.security(syminfo.tickerid, zoneTF, f_supplyZone(minMult, bodyRatio, neutralMax, baseLook, atrLen), barmerge.gaps_off, barmerge.lookahead_off)
[htf_sBull, htf_dBot, htf_dTop, htf_dTime] = request.security(syminfo.tickerid, zoneTF, f_demandZone(minMult, bodyRatio, neutralMax, baseLook, atrLen), barmerge.gaps_off, barmerge.lookahead_off)
htf_bidx = request.security(syminfo.tickerid, zoneTF, bar_index, barmerge.gaps_off, barmerge.lookahead_off)

// Draw zones once per new source-TF bar
is_new_htf = ta.change(htf_bidx) > 0

// Convert source-TF timestamp to current chart bar index
// time = current chart bar's timestamp; htf_xTime = base candle's timestamp
chartMs = timeframe.in_seconds() * 1000
f_leftBar(t) => na(t) ? bar_index : math.max(0, bar_index - math.round((time - t) / chartMs))

// ── ZONE STORAGE ──────────────────────────────────────────────────────────────
var box[]  supplyBoxes = array.new_box()
var bool[] supplyHit   = array.new_bool()
var box[]  demandBoxes = array.new_box()
var bool[] demandHit   = array.new_bool()

// ── DRAW SUPPLY ZONE ──────────────────────────────────────────────────────────
if is_new_htf and htf_sBear
    b = box.new(f_leftBar(htf_sTime), htf_sTop, bar_index, htf_sBot, border_color=supplyBorder, bgcolor=supplyFill, border_width=2, extend=extend.right)
    array.push(supplyBoxes, b)
    array.push(supplyHit, false)
    if array.size(supplyBoxes) > maxZones
        oldest = array.shift(supplyBoxes)
        if not array.shift(supplyHit)
            box.delete(oldest)

// ── DRAW DEMAND ZONE ──────────────────────────────────────────────────────────
if is_new_htf and htf_sBull
    b = box.new(f_leftBar(htf_dTime), htf_dTop, bar_index, htf_dBot, border_color=demandBorder, bgcolor=demandFill, border_width=2, extend=extend.right)
    array.push(demandBoxes, b)
    array.push(demandHit, false)
    if array.size(demandBoxes) > maxZones
        oldest = array.shift(demandBoxes)
        if not array.shift(demandHit)
            box.delete(oldest)

// ── MITIGATION ────────────────────────────────────────────────────────────────
if array.size(supplyBoxes) > 0
    for i = 0 to array.size(supplyBoxes) - 1
        if not array.get(supplyHit, i)
            b = array.get(supplyBoxes, i)
            if close <= box.get_top(b) and close >= box.get_bottom(b)
                array.set(supplyHit, i, true)
                box.set_extend(b, extend.none)
                box.set_right(b, bar_index)
                if showMit
                    box.set_bgcolor(b, mitFill)
                    box.set_border_color(b, color.new(color.gray, 50))
                else
                    box.delete(b)

if array.size(demandBoxes) > 0
    for i = 0 to array.size(demandBoxes) - 1
        if not array.get(demandHit, i)
            b = array.get(demandBoxes, i)
            if close >= box.get_bottom(b) and close <= box.get_top(b)
                array.set(demandHit, i, true)
                box.set_extend(b, extend.none)
                box.set_right(b, bar_index)
                if showMit
                    box.set_bgcolor(b, mitFill)
                    box.set_border_color(b, color.new(color.gray, 50))
                else
                    box.delete(b)
