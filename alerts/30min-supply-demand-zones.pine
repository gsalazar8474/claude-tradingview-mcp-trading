//@version=5
// Elder Santis - Supply & Demand Zones
//
// Rules (from rules.json + transcripts):
//   Only draw OBVIOUS, explosive moves. If it is not clear — skip it.
//   Cherry-pick only the clearest levels.
//
// SUPPLY ZONE (red):
//   Trigger : explosive bearish move — single massive red candle OR
//             3 consecutive red candles with combined body >= minMult x ATR
//   Base    : neutral candle(s) immediately BEFORE the move
//             scan stops the moment any candle body exceeds neutralMax x ATR
//   Top     : highest WICK  across all base candles
//   Bottom  : lowest  BODY-BOTTOM across all base candles
//
// DEMAND ZONE (green):
//   Trigger : explosive bullish move — single massive green candle OR
//             3 consecutive green candles with combined body >= minMult x ATR
//   Base    : neutral candle(s) immediately BEFORE the move
//   Top     : highest BODY-TOP across all base candles
//   Bottom  : lowest  WICK  across all base candles
//
// Zones extend right until price closes inside (mitigation).

indicator("Elder Santis - Supply & Demand Zones", overlay=true, max_bars_back=500, max_boxes_count=50)

// ── INPUTS ────────────────────────────────────────────────────────────────────
atrLen     = input.int(14,    "ATR Length",                  minval=1,   maxval=50)
minMult    = input.float(2.0, "Min Move Body (x ATR)",       minval=0.5, maxval=10.0, step=0.25, tooltip="Raise to draw fewer, more obvious zones only.")
bodyRatio  = input.float(0.5, "Min body / range ratio",      minval=0.3, maxval=1.0,  step=0.05, tooltip="Filters wicky indecisive candles. 0.5 = body must be at least half the range.")
neutralMax = input.float(0.5, "Base candle body max (x ATR)",minval=0.1, maxval=2.0,  step=0.1,  tooltip="Base scan stops when a candle body exceeds this. Keeps the base tight.")
baseLook   = input.int(6,     "Max base candles to scan",    minval=1,   maxval=15)
maxZones   = input.int(5,     "Max zones per side",          minval=1,   maxval=20)
showMit    = input.bool(false, "Show mitigated zones (greyed out)")
supplyCol    = input.color(color.new(color.red,   60), "Supply fill")
demandCol    = input.color(color.new(color.green, 60), "Demand fill")
mitCol       = input.color(color.new(color.gray,  88), "Mitigated fill")
supplyBorder = input.color(color.new(color.red,    0), "Supply border")
demandBorder = input.color(color.new(color.green,  0), "Demand border")

atr = ta.atr(atrLen)

// ── IMPULSE DETECTION ─────────────────────────────────────────────────────────
// Detect on the current confirmed bar (bar[0]).
// Base candles start immediately after the move: bar[1] for single-candle, bar[3] for 3-bar run.

curBody  = math.abs(open - close)
curRange = high - low

// Single explosive candle: body large, body is most of the range
singleBear = open > close and curRange > 0.0 and curBody >= minMult * atr and curBody / curRange >= bodyRatio
singleBull = close > open and curRange > 0.0 and curBody >= minMult * atr and curBody / curRange >= bodyRatio

// 3 consecutive same-direction candles: all bear/bull, combined body >= threshold
body3Bear = (open > close ? open - close : 0.0) + (open[1] > close[1] ? open[1] - close[1] : 0.0) + (open[2] > close[2] ? open[2] - close[2] : 0.0)
body3Bull = (close > open ? close - open : 0.0) + (close[1] > open[1] ? close[1] - open[1] : 0.0) + (close[2] > open[2] ? close[2] - open[2] : 0.0)
threeBear = open > close and open[1] > close[1] and open[2] > close[2] and body3Bear >= minMult * atr
threeBull = close > open and close[1] > open[1] and close[2] > open[2] and body3Bull >= minMult * atr

isBigBear = barstate.isconfirmed and not na(atr) and (singleBear or threeBear)
isBigBull = barstate.isconfirmed and not na(atr) and (singleBull or threeBull)

// Offset to the first base candle
bearBase = threeBear ? 3 : 1
bullBase = threeBull ? 3 : 1

// ── ZONE STORAGE ──────────────────────────────────────────────────────────────
var box[]  supplyBoxes = array.new_box()
var bool[] supplyHit   = array.new_bool()
var box[]  demandBoxes = array.new_box()
var bool[] demandHit   = array.new_bool()

// ── DRAW SUPPLY ZONE ──────────────────────────────────────────────────────────
if isBigBear
    bs      = bearBase
    zTop    = na(high[bs]) ? float(na) : high[bs]
    zBot    = na(open[bs]) or na(close[bs]) ? float(na) : math.min(open[bs], close[bs])
    leftBar = bar_index - bs
    for k = bs + 1 to bs + baseLook
        if na(open[k]) or na(close[k]) or na(high[k])
            break
        if math.abs(open[k] - close[k]) > neutralMax * nz(atr[k], atr)
            break
        zTop    := math.max(zTop, high[k])
        zBot    := math.min(zBot, math.min(open[k], close[k]))
        leftBar := bar_index - k
    if not na(zTop) and not na(zBot) and zTop > zBot
        b = box.new(leftBar, zTop, bar_index, zBot, border_color=supplyBorder, bgcolor=supplyCol, border_width=2, extend=extend.right)
        array.push(supplyBoxes, b)
        array.push(supplyHit, false)
        if array.size(supplyBoxes) > maxZones
            oldest = array.shift(supplyBoxes)
            if not array.shift(supplyHit)
                box.delete(oldest)

// ── DRAW DEMAND ZONE ──────────────────────────────────────────────────────────
if isBigBull
    bs      = bullBase
    zBot    = na(low[bs]) ? float(na) : low[bs]
    zTop    = na(open[bs]) or na(close[bs]) ? float(na) : math.max(open[bs], close[bs])
    leftBar = bar_index - bs
    for k = bs + 1 to bs + baseLook
        if na(open[k]) or na(close[k]) or na(low[k])
            break
        if math.abs(open[k] - close[k]) > neutralMax * nz(atr[k], atr)
            break
        zBot    := math.min(zBot, low[k])
        zTop    := math.max(zTop, math.max(open[k], close[k]))
        leftBar := bar_index - k
    if not na(zBot) and not na(zTop) and zTop > zBot
        b = box.new(leftBar, zTop, bar_index, zBot, border_color=demandBorder, bgcolor=demandCol, border_width=2, extend=extend.right)
        array.push(demandBoxes, b)
        array.push(demandHit, false)
        if array.size(demandBoxes) > maxZones
            oldest = array.shift(demandBoxes)
            if not array.shift(demandHit)
                box.delete(oldest)

// ── MITIGATION ────────────────────────────────────────────────────────────────
if array.size(supplyBoxes) > 0
    for i = 0 to array.size(supplyBoxes) - 1
        if not array.get(supplyHit, i)
            b = array.get(supplyBoxes, i)
            if close <= box.get_top(b) and close >= box.get_bottom(b)
                array.set(supplyHit, i, true)
                box.set_extend(b, extend.none)
                box.set_right(b, bar_index)
                if showMit
                    box.set_bgcolor(b, mitCol)
                    box.set_border_color(b, color.new(color.gray, 50))
                else
                    box.delete(b)

if array.size(demandBoxes) > 0
    for i = 0 to array.size(demandBoxes) - 1
        if not array.get(demandHit, i)
            b = array.get(demandBoxes, i)
            if close >= box.get_bottom(b) and close <= box.get_top(b)
                array.set(demandHit, i, true)
                box.set_extend(b, extend.none)
                box.set_right(b, bar_index)
                if showMit
                    box.set_bgcolor(b, mitCol)
                    box.set_border_color(b, color.new(color.gray, 50))
                else
                    box.delete(b)
