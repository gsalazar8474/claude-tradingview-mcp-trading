//@version=5
indicator("8AM Midpoint", overlay=true)

nyHour = hour(time,   "America/New_York")
nyMin  = minute(time, "America/New_York")

is815 = nyHour == 8 and nyMin == 15

var float hi  = na
var float lo  = na
var float mid = na

var line  lineHi  = na
var line  lineMid = na
var line  lineLo  = na
var label lblHi   = na
var label lblMid  = na
var label lblLo   = na

if is815
    hi  := high
    lo  := low
    mid := (high + low) / 2.0

    dayEnd = bar_index + 35

    if not na(lineHi)
        line.delete(lineHi)
    if not na(lineMid)
        line.delete(lineMid)
    if not na(lineLo)
        line.delete(lineLo)
    if not na(lblHi)
        label.delete(lblHi)
    if not na(lblMid)
        label.delete(lblMid)
    if not na(lblLo)
        label.delete(lblLo)

    lineHi  := line.new(bar_index, hi,  dayEnd, hi,  color=color.white, width=1, style=line.style_solid)
    lineMid := line.new(bar_index, mid, dayEnd, mid, color=color.white, width=1, style=line.style_dashed)
    lineLo  := line.new(bar_index, lo,  dayEnd, lo,  color=color.white, width=1, style=line.style_solid)

    lblHi   := label.new(bar_index, hi,  "0",   color=color.new(color.white, 60), textcolor=color.white, style=label.style_label_right, size=size.small)
    lblMid  := label.new(bar_index, mid, "0.5", color=color.new(color.white, 60), textcolor=color.white, style=label.style_label_right, size=size.small)
    lblLo   := label.new(bar_index, lo,  "1",   color=color.new(color.white, 60), textcolor=color.white, style=label.style_label_right, size=size.small)
