//@version=5
strategy("8AM Midpoint Strategy [XAUUSD]",
     overlay           = true,
     default_qty_type  = strategy.fixed,
     default_qty_value = 0.1)

// ─────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────
stopBuf    = input.float(2.0,  "SL Buffer (pts)")
minRR      = input.float(2.0,  "Min R:R")
maxPivBars = input.int(672,    "Max pivot staleness (bars)", minval = 50, maxval = 2000)

// ─────────────────────────────────────────────────────────────
// TIME  (America/New_York handles EST and EDT automatically)
// ─────────────────────────────────────────────────────────────
nyHour = hour(time,       "America/New_York")
nyMin  = minute(time,     "America/New_York")
nyDay  = dayofmonth(time, "America/New_York")

is815  = nyHour == 8  and nyMin == 15
isEOD  = nyHour == 16 and nyMin == 59
newDay = ta.change(nyDay) != 0

// ─────────────────────────────────────────────────────────────
// PIVOT TRACKING  (runs every bar, never reset)
// ta.pivotlow/pivothigh confirm with a 10-bar lag.
// We store the most recent confirmed value and its bar index.
// ─────────────────────────────────────────────────────────────
rawPivLow  = ta.pivotlow(10, 10)
rawPivHigh = ta.pivothigh(10, 10)

var float recentPivLow     = na
var float recentPivHigh    = na
var int   recentPivLowBar  = 0
var int   recentPivHighBar = 0

if not na(rawPivLow)
    recentPivLow    := rawPivLow
    recentPivLowBar := bar_index

if not na(rawPivHigh)
    recentPivHigh    := rawPivHigh
    recentPivHighBar := bar_index

pivLowOK  = not na(recentPivLow)  and (bar_index - recentPivLowBar)  <= maxPivBars
pivHighOK = not na(recentPivHigh) and (bar_index - recentPivHighBar) <= maxPivBars

// ─────────────────────────────────────────────────────────────
// DAILY STATE  (reset each new calendar day)
// ─────────────────────────────────────────────────────────────
var float lvlHigh   = na
var float lvlMid    = na
var float lvlLow    = na
var bool  bullBias  = false
var bool  bearBias  = false
var bool  tradeDone = false

if newDay
    lvlHigh   := na
    lvlMid    := na
    lvlLow    := na
    bullBias  := false
    bearBias  := false
    tradeDone := false

// ─────────────────────────────────────────────────────────────
// DRAWING OBJECTS
// ─────────────────────────────────────────────────────────────
var line  line0   = na
var line  line05  = na
var line  line1   = na
var label lbl0    = na
var label lbl05   = na
var label lbl1    = na
var line  tpLine  = na
var line  slLine  = na
var label tpLabel = na
var label slLabel = na

// ─────────────────────────────────────────────────────────────
// 8:15 AM — capture the range and draw the three level lines
// high = level 0,  midpoint = level 0.5,  low = level 1
// Lines extend ~35 bars forward (≈ 8h45m on 15min = end of NY session)
// ─────────────────────────────────────────────────────────────
if is815
    lvlHigh := high
    lvlLow  := low
    lvlMid  := (high + low) / 2.0

    endBar = bar_index + 35

    // Remove previous day's level lines
    if not na(line0)
        line.delete(line0)
    if not na(line05)
        line.delete(line05)
    if not na(line1)
        line.delete(line1)
    if not na(lbl0)
        label.delete(lbl0)
    if not na(lbl05)
        label.delete(lbl05)
    if not na(lbl1)
        label.delete(lbl1)

    // Remove previous day's SL / TP drawings
    if not na(tpLine)
        line.delete(tpLine)
    if not na(slLine)
        line.delete(slLine)
    if not na(tpLabel)
        label.delete(tpLabel)
    if not na(slLabel)
        label.delete(slLabel)

    // Level 0 — top (white solid)
    line0 := line.new(bar_index, lvlHigh, endBar, lvlHigh,
         color = color.white, width = 1, style = line.style_solid)
    lbl0  := label.new(bar_index, lvlHigh, "0",
         color     = color.new(color.white, 60),
         textcolor = color.white,
         style     = label.style_label_right,
         size      = size.small)

    // Level 0.5 — midpoint (white dashed)
    line05 := line.new(bar_index, lvlMid, endBar, lvlMid,
         color = color.white, width = 1, style = line.style_dashed)
    lbl05  := label.new(bar_index, lvlMid, "0.5",
         color     = color.new(color.white, 60),
         textcolor = color.white,
         style     = label.style_label_right,
         size      = size.small)

    // Level 1 — bottom (white solid)
    line1 := line.new(bar_index, lvlLow, endBar, lvlLow,
         color = color.white, width = 1, style = line.style_solid)
    lbl1  := label.new(bar_index, lvlLow, "1",
         color     = color.new(color.white, 60),
         textcolor = color.white,
         style     = label.style_label_right,
         size      = size.small)

// ─────────────────────────────────────────────────────────────
// BIAS DETECTION
// First bar AFTER 8:15 where close crosses the midpoint.
// Guard with (not is815) so the range-defining candle itself
// cannot trigger an entry.
// ─────────────────────────────────────────────────────────────
bullBreak = not na(lvlMid) and not is815 and not tradeDone
     and not bullBias and not bearBias
     and ta.crossover(close, lvlMid)

bearBreak = not na(lvlMid) and not is815 and not tradeDone
     and not bullBias and not bearBias
     and ta.crossunder(close, lvlMid)

if bullBreak
    bullBias := true
if bearBreak
    bearBias := true

// ─────────────────────────────────────────────────────────────
// LONG SETUP
// SL  = most recent confirmed pivot LOW  − stopBuf
// TP  = most recent confirmed pivot HIGH
// Only fires if R:R ≥ minRR
// ─────────────────────────────────────────────────────────────
if bullBias and not tradeDone
    tradeDone := true

    if pivLowOK and pivHighOK
        slPrice = recentPivLow  - stopBuf
        tpPrice = recentPivHigh
        risk    = lvlMid - slPrice
        reward  = tpPrice - lvlMid
        rr      = reward / risk

        if rr >= minRR
            strategy.entry("Long", strategy.long, limit = lvlMid, comment = "8AM_BUY")
            strategy.exit("Long Exit", "Long", limit = tpPrice, stop = slPrice)

            endBar = bar_index + 35

            if not na(tpLine)
                line.delete(tpLine)
            if not na(slLine)
                line.delete(slLine)
            if not na(tpLabel)
                label.delete(tpLabel)
            if not na(slLabel)
                label.delete(slLabel)

            tpLine := line.new(bar_index, tpPrice, endBar, tpPrice,
                 color = color.green, width = 2, style = line.style_dotted)
            slLine := line.new(bar_index, slPrice, endBar, slPrice,
                 color = color.red,   width = 2, style = line.style_dotted)
            tpLabel := label.new(bar_index, tpPrice,
                 "Take profit  " + str.tostring(tpPrice, "#.##") +
                 "   R:R 1:" + str.tostring(rr, "#.#"),
                 color     = color.new(color.green, 55),
                 textcolor = color.white,
                 style     = label.style_label_left,
                 size      = size.small)
            slLabel := label.new(bar_index, slPrice,
                 "Stop loss  " + str.tostring(slPrice, "#.##"),
                 color     = color.new(color.red, 55),
                 textcolor = color.white,
                 style     = label.style_label_left,
                 size      = size.small)

            alert('{"action":"buy","signal":"8am_midpoint","symbol":"{{ticker}}","price":"{{close}}","time":"{{timenow}}"}',
                  alert.freq_once_per_bar)

// ─────────────────────────────────────────────────────────────
// SHORT SETUP
// SL  = most recent confirmed pivot HIGH + stopBuf
// TP  = most recent confirmed pivot LOW
// Only fires if R:R ≥ minRR
// ─────────────────────────────────────────────────────────────
if bearBias and not tradeDone
    tradeDone := true

    if pivLowOK and pivHighOK
        slPrice = recentPivHigh + stopBuf
        tpPrice = recentPivLow
        risk    = slPrice - lvlMid
        reward  = lvlMid - tpPrice
        rr      = reward / risk

        if rr >= minRR
            strategy.entry("Short", strategy.short, limit = lvlMid, comment = "8AM_SELL")
            strategy.exit("Short Exit", "Short", limit = tpPrice, stop = slPrice)

            endBar = bar_index + 35

            if not na(tpLine)
                line.delete(tpLine)
            if not na(slLine)
                line.delete(slLine)
            if not na(tpLabel)
                label.delete(tpLabel)
            if not na(slLabel)
                label.delete(slLabel)

            tpLine := line.new(bar_index, tpPrice, endBar, tpPrice,
                 color = color.green, width = 2, style = line.style_dotted)
            slLine := line.new(bar_index, slPrice, endBar, slPrice,
                 color = color.red,   width = 2, style = line.style_dotted)
            tpLabel := label.new(bar_index, tpPrice,
                 "Take profit  " + str.tostring(tpPrice, "#.##") +
                 "   R:R 1:" + str.tostring(rr, "#.#"),
                 color     = color.new(color.green, 55),
                 textcolor = color.white,
                 style     = label.style_label_left,
                 size      = size.small)
            slLabel := label.new(bar_index, slPrice,
                 "Stop loss  " + str.tostring(slPrice, "#.##"),
                 color     = color.new(color.red, 55),
                 textcolor = color.white,
                 style     = label.style_label_left,
                 size      = size.small)

            alert('{"action":"sell","signal":"8am_midpoint","symbol":"{{ticker}}","price":"{{close}}","time":"{{timenow}}"}',
                  alert.freq_once_per_bar)

// ─────────────────────────────────────────────────────────────
// END OF DAY — cancel any unfilled limit orders
// ─────────────────────────────────────────────────────────────
if isEOD
    strategy.cancel_all()
