//@version=5
strategy("8AM Midpoint Strategy [XAUUSD]",
     overlay           = true,
     default_qty_type  = strategy.fixed,
     default_qty_value = 0.1)

// ═══════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════
pivLB      = input.int(10,    "Pivot Lookback (bars each side)", minval = 3, maxval = 20)
stopBuf    = input.float(2.0, "SL Buffer (pts)")
minRR      = input.float(2.0, "Min R:R")
maxPivBars = input.int(672,   "Max pivot staleness (bars)",      minval = 50, maxval = 2000)

// ═══════════════════════════════════════════════════════════
// TIME  (America/New_York handles EST/EDT automatically)
// ═══════════════════════════════════════════════════════════
nyHour = hour(time,       "America/New_York")
nyMin  = minute(time,     "America/New_York")
nyDay  = dayofmonth(time, "America/New_York")

is815  = nyHour == 8 and nyMin == 15
newDay = ta.change(nyDay) != 0

// ═══════════════════════════════════════════════════════════
// PIVOT TRACKING  (persistent across days)
// ta.pivotlow / pivothigh confirm with a pivLB-bar lag
// ═══════════════════════════════════════════════════════════
rawPivLow  = ta.pivotlow(pivLB, pivLB)
rawPivHigh = ta.pivothigh(pivLB, pivLB)

var float recentPivLow     = na
var float recentPivHigh    = na
var int   recentPivLowBar  = 0
var int   recentPivHighBar = 0

if not na(rawPivLow)
    recentPivLow    := rawPivLow
    recentPivLowBar := bar_index

if not na(rawPivHigh)
    recentPivHigh    := rawPivHigh
    recentPivHighBar := bar_index

pivLowValid  = not na(recentPivLow)  and (bar_index - recentPivLowBar)  <= maxPivBars
pivHighValid = not na(recentPivHigh) and (bar_index - recentPivHighBar) <= maxPivBars

// ═══════════════════════════════════════════════════════════
// DAILY STATE
// ═══════════════════════════════════════════════════════════
var float rangeHigh = na
var float rangeLow  = na
var float mid       = na
var bool  bullBias  = false
var bool  bearBias  = false
var bool  tradeDone = false

var line  topLine   = na
var line  midLine   = na
var line  botLine   = na
var label topLbl    = na
var label midLbl    = na
var label botLbl    = na
var line  tpLine    = na
var line  slLine    = na
var label tpLbl     = na
var label slLbl     = na

if newDay
    rangeHigh := na
    rangeLow  := na
    mid       := na
    bullBias  := false
    bearBias  := false
    tradeDone := false

// ═══════════════════════════════════════════════════════════
// 8:15 AM CANDLE — defines the range for the day
// High = level 0,  Low = level 1,  Mid = level 0.5
// ═══════════════════════════════════════════════════════════
if is815
    rangeHigh := high
    rangeLow  := low
    mid       := (high + low) / 2.0

    // Clear previous day's drawings
    if not na(topLine)
        line.delete(topLine)
    if not na(midLine)
        line.delete(midLine)
    if not na(botLine)
        line.delete(botLine)
    if not na(topLbl)
        label.delete(topLbl)
    if not na(midLbl)
        label.delete(midLbl)
    if not na(botLbl)
        label.delete(botLbl)
    if not na(tpLine)
        line.delete(tpLine)
    if not na(slLine)
        line.delete(slLine)
    if not na(tpLbl)
        label.delete(tpLbl)
    if not na(slLbl)
        label.delete(slLbl)

    // Level 0 — top (green)
    topLine := line.new(bar_index, rangeHigh, bar_index + 200, rangeHigh,
         color = color.green, width = 1, style = line.style_solid)
    topLbl  := label.new(bar_index, rangeHigh, "0",
         color     = color.new(color.green, 60),
         textcolor = color.white,
         style     = label.style_label_right,
         size      = size.small)

    // Level 0.5 — midpoint (white dashed)
    midLine := line.new(bar_index, mid, bar_index + 200, mid,
         color = color.white, width = 1, style = line.style_dashed)
    midLbl  := label.new(bar_index, mid, "0.5",
         color     = color.new(color.gray, 60),
         textcolor = color.white,
         style     = label.style_label_right,
         size      = size.small)

    // Level 1 — bottom (red)
    botLine := line.new(bar_index, rangeLow, bar_index + 200, rangeLow,
         color = color.red, width = 1, style = line.style_solid)
    botLbl  := label.new(bar_index, rangeLow, "1",
         color     = color.new(color.red, 60),
         textcolor = color.white,
         style     = label.style_label_right,
         size      = size.small)

// ═══════════════════════════════════════════════════════════
// BIAS DETECTION
// First close that crosses 0.5 sets the direction for the day
// ═══════════════════════════════════════════════════════════
bullBreak = not na(mid) and not tradeDone and not bullBias and not bearBias
     and ta.crossover(close, mid)
bearBreak = not na(mid) and not tradeDone and not bullBias and not bearBias
     and ta.crossunder(close, mid)

if bullBreak
    bullBias := true
if bearBreak
    bearBias := true

// ═══════════════════════════════════════════════════════════
// LONG SETUP
// SL = most recent pivot low − buffer
// TP = most recent pivot high
// ═══════════════════════════════════════════════════════════
if bullBias and not tradeDone
    tradeDone := true

    if pivLowValid and pivHighValid
        slPrice = recentPivLow  - stopBuf
        tpPrice = recentPivHigh
        risk    = mid - slPrice
        reward  = tpPrice - mid
        rr      = reward / risk

        if rr >= minRR
            strategy.entry("Long", strategy.long, limit = mid, comment = "8AM_BUY")
            strategy.exit("Long Exit", "Long", limit = tpPrice, stop = slPrice)

            if not na(tpLine)
                line.delete(tpLine)
            if not na(slLine)
                line.delete(slLine)
            if not na(tpLbl)
                label.delete(tpLbl)
            if not na(slLbl)
                label.delete(slLbl)

            tpLine := line.new(bar_index, tpPrice, bar_index + 100, tpPrice,
                 color = color.green, width = 2, style = line.style_dotted)
            slLine := line.new(bar_index, slPrice, bar_index + 100, slPrice,
                 color = color.red,   width = 2, style = line.style_dotted)
            tpLbl  := label.new(bar_index, tpPrice,
                 "Take profit: Last swing high  " + str.tostring(tpPrice, "#.##") +
                 "  |  R:R 1:" + str.tostring(rr, "#.#"),
                 color     = color.new(color.green, 55),
                 textcolor = color.white,
                 style     = label.style_label_left,
                 size      = size.small)
            slLbl  := label.new(bar_index, slPrice,
                 "Stop loss: Last swing low  " + str.tostring(slPrice, "#.##"),
                 color     = color.new(color.red, 55),
                 textcolor = color.white,
                 style     = label.style_label_left,
                 size      = size.small)

            alert('{"action":"buy","signal":"8am_midpoint","symbol":"{{ticker}}","price":"{{close}}","time":"{{timenow}}"}',
                  alert.freq_once_per_bar)

// ═══════════════════════════════════════════════════════════
// SHORT SETUP
// SL = most recent pivot high + buffer
// TP = most recent pivot low
// ═══════════════════════════════════════════════════════════
if bearBias and not tradeDone
    tradeDone := true

    if pivLowValid and pivHighValid
        slPrice = recentPivHigh + stopBuf
        tpPrice = recentPivLow
        risk    = slPrice - mid
        reward  = mid - tpPrice
        rr      = reward / risk

        if rr >= minRR
            strategy.entry("Short", strategy.short, limit = mid, comment = "8AM_SELL")
            strategy.exit("Short Exit", "Short", limit = tpPrice, stop = slPrice)

            if not na(tpLine)
                line.delete(tpLine)
            if not na(slLine)
                line.delete(slLine)
            if not na(tpLbl)
                label.delete(tpLbl)
            if not na(slLbl)
                label.delete(slLbl)

            tpLine := line.new(bar_index, tpPrice, bar_index + 100, tpPrice,
                 color = color.green, width = 2, style = line.style_dotted)
            slLine := line.new(bar_index, slPrice, bar_index + 100, slPrice,
                 color = color.red,   width = 2, style = line.style_dotted)
            tpLbl  := label.new(bar_index, tpPrice,
                 "Take profit: Last swing low  " + str.tostring(tpPrice, "#.##") +
                 "  |  R:R 1:" + str.tostring(rr, "#.#"),
                 color     = color.new(color.green, 55),
                 textcolor = color.white,
                 style     = label.style_label_left,
                 size      = size.small)
            slLbl  := label.new(bar_index, slPrice,
                 "Stop loss: Last swing high  " + str.tostring(slPrice, "#.##"),
                 color     = color.new(color.red, 55),
                 textcolor = color.white,
                 style     = label.style_label_left,
                 size      = size.small)

            alert('{"action":"sell","signal":"8am_midpoint","symbol":"{{ticker}}","price":"{{close}}","time":"{{timenow}}"}',
                  alert.freq_once_per_bar)
