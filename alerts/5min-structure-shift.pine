//@version=5
// Elder Santis - 5min Structure Shift Alert
// BULLISH SHIFT = higher high + higher low  -> look for long entry trigger
// BEARISH SHIFT = lower low  + lower high   -> look for short entry trigger
//
// Chart timeframe : 5min  (OANDA:XAUUSD or FX:XAUUSD)
// Webhook URL     : https://claude-tradingview-mcp-trading-production-f418.up.railway.app/webhook
// Message BULLISH : {"action":"buy","signal":"5min_structure_shift","symbol":"{{ticker}}","close":"{{close}}","time":"{{timenow}}"}
// Message BEARISH : {"action":"sell","signal":"5min_structure_shift","symbol":"{{ticker}}","close":"{{close}}","time":"{{timenow}}"}

indicator("Elder Santis - 5min Structure Shift", overlay=true, max_bars_back=300)

pivotLen   = input.int(3, "Pivot Lookback (bars each side)", minval=2, maxval=8)
showLabels = input.bool(true, "Show shift labels on chart")
showBg     = input.bool(true, "Show background colour on shift")

pivotHigh = ta.pivothigh(high, pivotLen, pivotLen)
pivotLow  = ta.pivotlow(low, pivotLen, pivotLen)

var float prevHigh = na
var float lastHigh = na
var float prevLow  = na
var float lastLow  = na

if not na(pivotHigh)
    prevHigh := lastHigh
    lastHigh := pivotHigh

if not na(pivotLow)
    prevLow := lastLow
    lastLow  := pivotLow

allDefined   = not na(prevHigh) and not na(lastHigh) and not na(prevLow) and not na(lastLow)
bullishShift = allDefined and lastHigh > prevHigh and lastLow > prevLow
bearishShift = allDefined and lastLow < prevLow and lastHigh < prevHigh
bullishNew   = bullishShift and not bullishShift[1]
bearishNew   = bearishShift and not bearishShift[1]

bgcolor(showBg and bullishShift ? color.new(color.green, 88) : showBg and bearishShift ? color.new(color.red, 88) : na, title="Shift Background")

plotshape(not na(pivotHigh), style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 30), size=size.tiny, title="5m Pivot High")
plotshape(not na(pivotLow), style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 30), size=size.tiny, title="5m Pivot Low")

if showLabels and bullishNew
    label.new(bar_index, low * 0.9995, "BULLISH\nHH + HL", color=color.new(color.green, 10), textcolor=color.white, style=label.style_label_up, size=size.small)

if showLabels and bearishNew
    label.new(bar_index, high * 1.0005, "BEARISH\nLL + LH", color=color.new(color.red, 10), textcolor=color.white, style=label.style_label_down, size=size.small)

alertcondition(bullishNew, "5min Bullish Shift", "5min structure shifted BULLISH (HH + HL). Check Bookmap for exhaustion/absorption. Look for long entry trigger.")
alertcondition(bearishNew, "5min Bearish Shift", "5min structure shifted BEARISH (LL + LH). Check Bookmap for exhaustion/absorption. Look for short entry trigger.")
